-- AUTO FARM (tween entre waypoints, 350 studs/segundo, 15s de pausa)
------------------------------------------------------------------------

local waypointsAutofarm = {
    Vector3.new(-54, 37, 644),
    Vector3.new(-58, 37, 1452),
    Vector3.new(-62, 37, 2123),
    Vector3.new(-65, 37, 2650),
    Vector3.new(-69, 37, 3292),
    Vector3.new(-75, 37, 4179),
    Vector3.new(-80, 37, 4962),
    Vector3.new(-85, 37, 5748),
    Vector3.new(-89, 37, 6490),
    Vector3.new(-94, 37, 7320),
    Vector3.new(-98, 37, 7941),
    Vector3.new(-102, 37, 8513),
    Vector3.new(-104, 37, 8751),
    Vector3.new(-128, -283, 8751),
    Vector3.new(-131, -283, 9276),
    Vector3.new(-55, -349, 9497),
    Vector3.new(-56, -345, 9500),
    Vector3.new(-55, -358, 9494),
}

local isAutoFarmEnabled = false
local autoFarmConnection = nil

-- Move HumanoidRootPart com velocidade ~350
local function moveHrpTo(hrp, target, onDone)
    local distance = (target - hrp.Position).Magnitude
    local duration = distance / 380  -- 350 studs/segundo
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = TweenService:Create(hrp, info, {CFrame = CFrame.new(target)})
    tween:Play()
    tween.Completed:Connect(function()
        if onDone then onDone() end
    end)
end

-- Percorre todos os waypoints em loop + 15s de pausa após o último
local function runAutoFarmWaypoints(hrp)
    local index = 1
    local function nextWaypoint()
        if not isAutoFarmEnabled or not hrp or not hrp.Parent then return end
        if index > #waypointsAutofarm then
            -- Espera 15 segundos antes de recomeçar o ciclo
            task.spawn(function()
                wait(15)
                if isAutoFarmEnabled and hrp and hrp.Parent then
                    index = 1
                    nextWaypoint()
                end
            end)
            return
        end
        local pos = waypointsAutofarm[index]
        moveHrpTo(hrp, pos, function()
            if isAutoFarmEnabled and hrp and hrp.Parent then
                index = index + 1
                nextWaypoint()
            end
        end)
    end
    nextWaypoint()
end

-- Ativar Auto Farm
local function startAutoFarm()
    if isAutoFarmEnabled then return end
    isAutoFarmEnabled = true
    autoFarmBtn.Text = "🟢 Auto Farm: ON"

    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Parent:FindFirstChild("Humanoid") then
        runAutoFarmWaypoints(hrp)
    end

    if autoFarmConnection then autoFarmConnection:Disconnect() end
    autoFarmConnection = player.CharacterAdded:Connect(function(char)
        if not isAutoFarmEnabled then return end
        local hrp = char:WaitForChild("HumanoidRootPart")
        wait(0.3)
        runAutoFarmWaypoints(hrp)
    end)
end

-- Desativar Auto Farm
local function stopAutoFarm()
    if not isAutoFarmEnabled then return end
    isAutoFarmEnabled = false
    autoFarmBtn.Text = "🔴 Auto Farm: OFF"
    if autoFarmConnection then
        autoFarmConnection:Disconnect()
        autoFarmConnection = nil
    end
end

-- Toggle do botão Auto Farm
autoFarmBtn.MouseButton1Click:Connect(function()
    if isAutoFarmEnabled then
        stopAutoFarm()
    else
        startAutoFarm()
    end
end)

------------------------------------------------------------------------
-- ANTI AFK (pulo automático a cada 5 segundos)
------------------------------------------------------------------------

local isAntiAfkEnabled = false
local antiAfkLoopConnection = nil

-- Função de pulo automático (AntiAfk)
local function startAntiAfk()
    if isAntiAfkEnabled then return end
    isAntiAfkEnabled = true
    antiAfkBtn.Text = "🟢 AntiAfk: ON"

    local function jump()
        local character = player.Character
        if not character then return end
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid and humanoid.Parent and humanoid.Health > 0 then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end

    -- Loop de pulo a cada 5 segundos
    local function loop()
        while isAntiAfkEnabled do
            jump()
            wait(2)
        end
    end

    -- Roda o loop em uma nova thread
    if antiAfkLoopConnection then
        antiAfkLoopConnection = nil
    end
    antiAfkLoopConnection = task.spawn(loop)
end

local function stopAntiAfk()
    if not isAntiAfkEnabled then return end
    isAntiAfkEnabled = false
    antiAfkBtn.Text = "🔴 AntiAfk: OFF"
    if antiAfkLoopConnection then
        antiAfkLoopConnection = nil
    end
end

-- Toggle do botão AntiAfk
antiAfkBtn.MouseButton1Click:Connect(function()
    if isAntiAfkEnabled then
        stopAntiAfk()
    else
        startAntiAfk()
    end
end)

------------------------------------------------------------------------
-- CHÃO 20×1×20 SEMPRE NOS PÉS (MESMO SE VOCÊ MORRER)
------------------------------------------------------------------------

local feetGroundBlock = nil

local function createFeetGroundBlock()
    -- Destroi o bloco anterior, se existir
    if feetGroundBlock and feetGroundBlock.Parent then
        feetGroundBlock:Destroy()
    end

    -- Espera o Character e o HumanoidRootPart
    local char = player.Character or player:WaitForChild("Character")
    local hrp = char:WaitForChild("HumanoidRootPart")

    -- Cria o bloco 20×1×20
    feetGroundBlock = Instance.new("Part")
    feetGroundBlock.Name = "InvisiblePart"
    feetGroundBlock.Size = Vector3.new(20, 1, 20)  -- 20, 1, 20
    feetGroundBlock.Anchored = true
    feetGroundBlock.Transparency = 1              -- totalmente invisível
    feetGroundBlock.CanCollide = true             -- se quiser, mude para false
    feetGroundBlock.CastShadow = false
    feetGroundBlock.Parent = workspace

    -- Coloca 1.5 studs abaixo do HRP (no chão, embaixo dos seus pés)
    feetGroundBlock.CFrame = CFrame.new(hrp.Position) * CFrame.new(0, -1.5, 0)

    -- Vincula para o HRP atual e sempre acompanhar a posição
    RunService.Heartbeat:Connect(function()
        if not feetGroundBlock or not feetGroundBlock.Parent then return end
        local currentHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not currentHrp then return end

        feetGroundBlock.CFrame = CFrame.new(currentHrp.Position) * CFrame.new(0, -1.5, 0)
    end)
end

-- Quando ganhar um novo character (morreu e reapareceu)
player.CharacterAdded:Connect(function(char)
    createFeetGroundBlock()
    -- Se o AntiAfk estiver ligado, reativa o loop
    if isAntiAfkEnabled then
        startAntiAfk()
    end
end)

-- Se você já estiver vivo quando o script carregar
if player.Character then
    createFeetGroundBlock()
end
